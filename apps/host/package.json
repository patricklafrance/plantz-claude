{
    "name": "@apps/host",
    "description": "Squide host application for the plantz application.",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "rsbuild dev --config rsbuild.dev.ts",
        "build": "rsbuild build --config rsbuild.build.ts",
        "serve-build": "pnpm http-server dist -p 8080 -P http://localhost:8080? -c-1",
        "typecheck": "tsgo"
    },
    "dependencies": {
        "@modules/management-plants": "workspace:*",
        "@modules/today-landing-page": "workspace:*",
        "@squide/firefly": "16.1.12",
        "@tanstack/react-query": "5.90.21",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-router": "7.12.0"
    },
    "devDependencies": {
        "@rsbuild/core": "1.7.2",
        "@types/react": "19.2.9",
        "@types/react-dom": "19.2.3",
        "@typescript/native-preview": "7.0.0-dev.20260303.1",
        "@workleap/browserslist-config": "2.1.5",
        "@workleap/rsbuild-configs": "3.2.0",
        "@workleap/typescript-configs": "3.0.7",
        "http-server": "14.1.1",
        "typescript": "5.9.3"
    }
}
