{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/pre-bash--lint-on-commit.sh"
                    },
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/pre-bash--no-file-level-disable-on-commit.sh"
                    },
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/pre-bash--enforce-pnpm.sh"
                    }
                ]
            },
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/pre-edit--protect-files.sh"
                    },
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/pre-edit--module-import-guard.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/post-edit--format.sh"
                    },
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/post-edit--lint.sh"
                    }
                ]
            }
        ]
    }
}
