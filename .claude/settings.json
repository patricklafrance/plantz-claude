{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/pre-commit.sh"
                    },
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/enforce-pnpm.sh"
                    }
                ]
            },
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/protect-files.sh"
                    },
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/module-import-guard.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/auto-format.sh"
                    }
                ]
            }
        ]
    }
}
