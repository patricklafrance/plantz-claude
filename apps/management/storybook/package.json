{
    "name": "@apps/management-storybook",
    "version": "0.0.0",
    "private": true,
    "description": "Storybook application for the management domain.",
    "type": "module",
    "scripts": {
        "dev": "storybook dev -p 6006 --disable-telemetry",
        "build-storybook": "storybook build --disable-telemetry",
        "serve-storybook": "pnpm http-server storybook-static -p 8080 -P http://localhost:8080? -c-1",
        "test": "pnpm run --sequential \"/^test:.*/\"",
        "test:light": "vitest run",
        "test:dark": "cross-env STORYBOOK_THEME=dark vitest run",
        "typecheck": "tsgo",
        "doctor": "storybook doctor"
    },
    "dependencies": {
        "@packages/components": "workspace:*",
        "@packages/plants-core": "workspace:*",
        "@squide/env-vars": "1.4.19",
        "@squide/firefly": "16.2.0",
        "@squide/launch-darkly": "1.0.10",
        "@squide/msw": "4.0.17",
        "@storybook/addon-a11y": "10.2.15",
        "@storybook/addon-themes": "10.2.15",
        "@storybook/addon-vitest": "10.2.15",
        "@storybook/react-vite": "10.2.15",
        "@tanstack/react-query": "5.90.21",
        "@workleap/logging": "1.3.6",
        "msw": "2.12.10",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-router": "7.12.0",
        "storybook": "10.2.15"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "4.2.1",
        "@types/react": "19.2.9",
        "@types/react-dom": "19.2.3",
        "@typescript/native-preview": "7.0.0-dev.20260303.1",
        "@vitest/browser": "4.1.0",
        "@vitest/browser-playwright": "4.1.0",
        "@vitest/runner": "4.1.0",
        "@workleap/typescript-configs": "3.0.7",
        "http-server": "14.1.1",
        "msw-storybook-addon": "2.0.6",
        "playwright": "1.52.0",
        "typescript": "5.9.3",
        "vite": "6.3.5",
        "vitest": "4.1.0"
    },
    "msw": {
        "workerDirectory": ".storybook/public"
    }
}
