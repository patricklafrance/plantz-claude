{
    "$schema": "./node_modules/turbo/schema.json",
    "ui": "tui",
    "tasks": {
        "transit": {
            "dependsOn": ["^transit"],
            "outputs": []
        },
        "dev": {
            "dependsOn": ["^dev"],
            "cache": false,
            "persistent": true
        },
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", "!README.md"],
            "env": ["MODULES"],
            "outputs": ["dist/**"]
        },
        "build-storybook": {
            "cache": false
        },
        "serve-build": {
            "dependsOn": ["build"],
            "cache": false,
            "persistent": true
        },
        "serve-storybook": {
            "dependsOn": ["build-storybook"],
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["typecheck", "//#typecheck", "//#syncpack"]
            // "dependsOn": ["eslint", "//#eslint", "stylelint", "typecheck", "//#typecheck", "//#syncpack"]
        },
        // "//#eslint": {
        //     "inputs": ["$TURBO_DEFAULT$", "!apps", "!packages", "!agent-docs", "!README.md", "!**/*.css"],
        //     "outputs": ["node_modules/.cache/eslint"]
        // },
        // "eslint": {
        //     "dependsOn": ["transit"],
        //     "inputs": ["$TURBO_DEFAULT$", "!README.md", "!src/**/*.css"],
        //     "outputs": ["node_modules/.cache/eslint"]
        // },
        // "stylelint": {
        //     "inputs": ["src/**/*.css", ".stylelintignore", ".stylelintrc.json"],
        //     "outputs": ["node_modules/.cache/stylelint"]
        // },
        "//#typecheck": {
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "test/**/*.tsx", "tsconfig.json", "!apps", "!packages", "!agent-docs"],
            "outputs": ["node_modules/.cache/tsbuildinfo.json"]
        },
        "typecheck": {
            "dependsOn": ["transit"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "test/**/*.tsx", "tsconfig.json", "tsconfig.build.json"],
            "outputs": ["node_modules/.cache/tsbuildinfo.json"]
        },
        "//#syncpack": {
            "inputs": [".syncpackrc.js", "package.json", "packages/**/package.json", "apps/**/package.json"]
        },
        "test": {
            "dependsOn": ["transit"],
            "outputs": ["node_modules/.cache/vitest/**"]
        }
    }
}
