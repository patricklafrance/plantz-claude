{
    "search.exclude": {
        "**/node_modules*": true,
        "**/dist*": true
    },

    // Formatting — handled by oxfmt via the oxc extension
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true,
    "[html]": {
        "editor.formatOnSave": false
    },

    // Languages
    "typescript.preferences.useAliasesForRenames": false,
    "typescript.tsdk": "node_modules\\typescript\\lib",

    "javascript.preferences.useAliasesForRenames": false,

    "css.validate": false, // Disables the default validation — Tailwind CSS uses non-standard syntax

    // Settings for third parties that are frequently used
    "files.associations": {
        "*.snap": "javascriptreact",
        "turbo.json": "jsonc"
    },

    "github.copilot.chat.commitMessageGeneration.instructions": [
        {
            "file": ".github/copilot/commit-message-instructions.md"
        }
    ],

    "chat.useAgentSkills": true,

    "json.schemas": [
        {
            "fileMatch": ["chromatic.config.json"],
            "url": "https://www.chromatic.com/config-file.schema.json"
        }
    ]
}
