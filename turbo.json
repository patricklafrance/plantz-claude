{
    "$schema": "./node_modules/turbo/schema.json",
    "ui": "tui",
    "tasks": {
        "transit": {
            "dependsOn": ["^transit"],
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", "!README.md"],
            "env": ["MODULES"],
            "outputs": ["dist/**"]
        },
        "build-storybook": {
            "cache": false
        },
        "serve-build": {
            "dependsOn": ["build"],
            "cache": false,
            "persistent": true
        },
        "serve-storybook": {
            "dependsOn": ["build-storybook"],
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["//#oxlint", "//#oxfmt", "typecheck", "//#typecheck", "//#syncpack"]
        },
        "//#oxlint": {
            "inputs": ["$TURBO_DEFAULT$", "!agent-docs", "!README.md"],
            "outputs": []
        },
        "//#typecheck": {
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "test/**/*.tsx", "tsconfig.json", "!apps", "!packages", "!agent-docs"],
            "outputs": ["node_modules/.cache/tsbuildinfo.json"]
        },
        "typecheck": {
            "dependsOn": ["transit"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "test/**/*.tsx", "tsconfig.json", "tsconfig.build.json"],
            "outputs": ["node_modules/.cache/tsbuildinfo.json"]
        },
        "//#oxfmt": {
            "inputs": ["$TURBO_DEFAULT$", "!agent-docs", "!README.md"],
            "outputs": []
        },
        "//#syncpack": {
            "inputs": [".syncpackrc.js", "package.json", "packages/**/package.json", "apps/**/package.json"]
        },
        "test": {
            "dependsOn": ["transit"],
            "outputs": ["node_modules/.cache/vitest/**"]
        }
    }
}
